# ============================================================
# clawctl environment variables — copy to .env and fill in.
# NEVER commit .env (it is in .gitignore).
# ============================================================

# --- Hetzner (required for 'clawctl server' commands) ---
HCLOUD_TOKEN=

# --- OpenClaw Gateway (generate with: openssl rand -hex 32) ---
OPENCLAW_GATEWAY_TOKEN=

# --- LLM Provider (at least one required) ---
OPENROUTER_API_KEY=

# --- Telegram Bot ---
# Create via @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=

# --- Web Search (optional, at least one recommended) ---
BRAVE_API_KEY=
# PERPLEXITY_API_KEY=

# --- OpenClaw paths (defaults work for the Docker compose setup) ---
OPENCLAW_CONFIG_DIR=/opt/openclaw/data
OPENCLAW_WORKSPACE_DIR=/opt/openclaw/workspace

# --- Databricks Free Edition (optional — for data analytics integration) ---
# Sign up free at https://signup.databricks.com (no credit card required)
# Get a PAT from: Databricks workspace → User Settings → Developer → Access tokens
DATABRICKS_HOST=
DATABRICKS_TOKEN=
# Your 2X-Small SQL warehouse ID (copy from: SQL → SQL Warehouses → Connection details)
DATABRICKS_WAREHOUSE_ID=
